<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logaritma - Proposal & Demo Website</title>
    <style>
        /* =================================================================
           BASE RESETS & VARIABLES
           ================================================================= */
        :root {
            --navy-dark: #0a192f;
            --navy-blue: #112240;
            --navy-light: #233554;
            --orange-red: #ff4757;
            --orange-hover: #ff6b81;
            --emerald-green: #10b981;
            --emerald-hover: #059669;
            --clean-white: #ffffff;
            --off-white: #f8fafc;
            --gray-border: #e2e8f0;
            --gray-text: #64748b;
            --text-dark: #1e293b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            background-color: var(--navy-dark);
            color: var(--clean-white);
            overflow-x: hidden;
        }

        /* =================================================================
           PAGE TRANSITIONS LOGIC
           ================================================================= */
        .page {
            display: none;
            opacity: 0;
            transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .page.active {
            display: block;
            opacity: 1;
        }

        /* =================================================================
           HALAMAN 1: LANDING PAGE PROPOSAL
           ================================================================= */
        #page1 {
            background-color: var(--navy-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
            background-image: radial-gradient(circle at top center, rgba(255, 71, 87, 0.15), transparent 60%);
        }

        .p1-container {
            max-width: 900px;
            text-align: center;
        }

        .urgency-badge {
            background: rgba(255, 71, 87, 0.2);
            color: var(--orange-red);
            padding: 10px 25px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1rem;
            display: inline-block;
            margin-bottom: 30px;
            border: 1px solid rgba(255, 71, 87, 0.4);
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: blink 2s infinite;
        }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        .p1-headline {
            font-size: 3.5rem;
            line-height: 1.2;
            font-weight: 900;
            margin-bottom: 30px;
            text-shadow: 0 5px 15px rgba(0,0,0,0.5);
            color: var(--clean-white);
        }
        .p1-headline span {
            color: var(--orange-red);
            position: relative;
            display: inline-block;
        }
        .p1-headline span::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background-color: var(--orange-red);
            border-radius: 3px;
        }

        .p1-subheadline {
            font-size: 1.3rem;
            color: #cbd5e1;
            margin-bottom: 40px;
            font-weight: 400;
            line-height: 1.7;
        }

        .p1-body {
            background: rgba(17, 34, 64, 0.7);
            padding: 40px;
            border-radius: 16px;
            border-left: 6px solid var(--orange-red);
            margin-bottom: 60px;
            text-align: left;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }
        .p1-body p {
            font-size: 1.15rem;
            margin-bottom: 20px;
            color: #94a3b8;
        }
        .p1-body p:last-child { margin-bottom: 0; }
        .p1-body strong { color: var(--clean-white); }

        .btn-to-demo {
            background: linear-gradient(135deg, var(--orange-red), #ff6b81);
            color: var(--clean-white);
            font-size: 1.4rem;
            font-weight: 800;
            padding: 25px 50px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 10px 25px rgba(255, 71, 87, 0.4), 0 0 0 0 rgba(255, 71, 87, 0.7);
            animation: pulseRed 2s infinite;
            transition: all 0.3s;
        }
        .btn-to-demo:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(255, 71, 87, 0.6);
        }
        @keyframes pulseRed {
            0% { box-shadow: 0 0 0 0 rgba(255, 71, 87, 0.7); }
            70% { box-shadow: 0 0 0 25px rgba(255, 71, 87, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 71, 87, 0); }
        }

        /* =================================================================
           HALAMAN 2: DEMO LIVE HOMEPAGE LOGARITMA
           ================================================================= */
        #page2 {
            background-color: var(--off-white);
            color: var(--text-dark);
            min-height: 100vh;
        }

        /* Header Navigation */
        .p2-header {
            background-color: var(--clean-white);
            padding: 20px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .p2-logo {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--navy-dark);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .p2-logo svg {
            width: 32px;
            height: 32px;
            fill: var(--emerald-green);
        }
        
        .p2-nav {
            display: flex;
            gap: 30px;
        }
        .p2-nav a {
            text-decoration: none;
            color: var(--gray-text);
            font-weight: 600;
            font-size: 1.05rem;
            transition: color 0.3s;
        }
        .p2-nav a:hover, .p2-nav a.active {
            color: var(--emerald-green);
        }
        
        .hamburger {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--navy-dark);
        }
        .hamburger svg { width: 30px; height: 30px; fill: currentColor; }

        /* Mobile Nav */
        .mobile-menu {
            display: none;
            flex-direction: column;
            background-color: var(--clean-white);
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            box-shadow: 0 10px 15px rgba(0,0,0,0.05);
            padding: 20px;
        }
        .mobile-menu.open {
            display: flex;
        }
        .mobile-menu a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 600;
            padding: 15px 0;
            border-bottom: 1px solid var(--gray-border);
        }

        /* Hero Section */
        .p2-hero {
            background-color: var(--navy-dark);
            color: var(--clean-white);
            padding: 100px 5% 120px;
            text-align: center;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" opacity="0.05"><path d="M0 0h100v100H0z" fill="none"/><circle cx="50" cy="50" r="40" stroke="white" stroke-width="2" fill="none"/></svg>');
            background-size: 150px;
        }
        .p2-hero h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 25px;
            line-height: 1.2;
        }
        .p2-hero p.hero-desc {
            font-size: 1.2rem;
            color: #94a3b8;
            max-width: 800px;
            margin: 0 auto 50px;
        }

        /* CTA Button Page 2 */
        .btn-cta-domain {
            background-color: var(--emerald-green);
            color: var(--clean-white);
            font-size: 1.2rem;
            font-weight: 700;
            padding: 18px 35px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
            transition: all 0.3s;
            display: inline-block;
            text-decoration: none;
            text-align: center;
        }
        .btn-cta-domain:hover {
            background-color: var(--emerald-hover);
            transform: translateY(-3px);
            box-shadow: 0 15px 25px rgba(16, 185, 129, 0.4);
        }

        /* Diagram Visual */
        .diagram-wrapper {
            max-width: 1000px;
            margin: -60px auto 80px;
            background: var(--clean-white);
            padding: 50px 30px;
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            position: relative;
            z-index: 10;
        }
        .diagram-title {
            text-align: center;
            color: var(--navy-dark);
            margin-bottom: 40px;
            font-size: 1.5rem;
            font-weight: 800;
        }
        
        .flex-diagram {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
        }
        .sub-system-row {
            display: flex;
            gap: 20px;
            width: 100%;
            justify-content: center;
        }
        .sub-box {
            flex: 1;
            background: #f8fafc;
            border: 2px solid var(--gray-border);
            padding: 25px 20px;
            border-radius: 12px;
            text-align: center;
            color: var(--navy-dark);
            font-weight: 700;
            font-size: 1.1rem;
            position: relative;
        }
        .sub-box::after {
            content: '';
            position: absolute;
            bottom: -30px;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            height: 30px;
            background-color: var(--emerald-green);
        }
        
        .connector-bar {
            width: calc(66% + 20px);
            height: 2px;
            background-color: var(--emerald-green);
            position: relative;
        }
        .connector-bar::after {
            content: '';
            position: absolute;
            bottom: -30px;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            height: 30px;
            background-color: var(--emerald-green);
        }

        .main-sys-box {
            background: var(--emerald-green);
            color: var(--clean-white);
            padding: 20px 50px;
            border-radius: 50px;
            font-size: 1.3rem;
            font-weight: 800;
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
            position: relative;
            z-index: 2;
        }
        .main-sys-box::before {
            content: '';
            position: absolute;
            top: -10px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 10px 10px 0;
            border-style: solid;
            border-color: var(--emerald-green) transparent transparent transparent;
        }

        /* Konten Utama */
        .p2-content {
            padding: 0 5% 100px;
            max-width: 1100px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }
        .content-text h2 {
            font-size: 2.2rem;
            color: var(--navy-dark);
            margin-bottom: 25px;
            font-weight: 800;
        }
        .content-text p {
            font-size: 1.1rem;
            color: var(--gray-text);
            margin-bottom: 20px;
        }
        .content-image {
            background: #e2e8f0;
            border-radius: 16px;
            height: 350px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            font-size: 1.2rem;
            font-weight: 600;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.05);
        }
        .content-image svg { width: 80px; height: 80px; fill: #cbd5e1; margin-bottom: 15px;}

        /* Footer */
        .p2-footer {
            background-color: var(--navy-dark);
            color: #94a3b8;
            padding: 60px 5% 40px;
            text-align: center;
        }
        .p2-footer .cta-wrapper { margin-bottom: 50px; }
        .p2-footer p { font-size: 0.95rem; }
        .p2-footer p a { color: var(--emerald-green); text-decoration: none; }
        .p2-footer a.btn-cta-domain { color: var(--clean-white); }

        /* Floating WhatsApp Button */
        .fab-wa {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background-color: #25D366;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(37, 211, 102, 0.4);
            cursor: pointer;
            transition: all 0.3s;
            z-index: 2000;
            animation: floatWA 3s ease-in-out infinite;
        }
        .fab-wa svg { width: 35px; height: 35px; fill: var(--clean-white); }
        .fab-wa:hover {
            transform: scale(1.1);
            background-color: #128C7E;
        }
        @keyframes floatWA {
            0% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0); }
        }

        /* =================================================================
           RESPONSIVE DESIGN (MEDIA QUERIES)
           ================================================================= */
        @media (max-width: 992px) {
            .p1-headline { font-size: 2.8rem; }
            .p2-hero h1 { font-size: 2.4rem; }
            .p2-content { grid-template-columns: 1fr; gap: 40px; }
            .content-image { height: 250px; }
        }

        @media (max-width: 768px) {
            .p1-headline { font-size: 2.2rem; }
            .p1-subheadline { font-size: 1.1rem; }
            .p1-body { padding: 25px; }
            .btn-to-demo { font-size: 1.1rem; padding: 20px 30px; width: 100%; }
            
            .p2-nav { display: none; }
            .hamburger { display: block; }
            
            .p2-hero { padding: 80px 5% 100px; }
            .sub-system-row { flex-direction: column; gap: 15px; }
            .sub-box::after { display: none; }
            .connector-bar { display: none; }
            
            /* Custom connector for mobile stacking */
            .sub-box {
                margin-bottom: 20px;
            }
            .sub-box:not(:last-child)::before {
                content: '';
                position: absolute;
                bottom: -22px;
                left: 50%;
                transform: translateX(-50%);
                width: 2px;
                height: 20px;
                background-color: var(--emerald-green);
            }
            
            .flex-diagram { gap: 10px; }
            .main-sys-box { margin-top: 20px; font-size: 1.1rem; text-align: center; }
            
            .fab-wa { bottom: 20px; right: 20px; width: 50px; height: 50px; }
            .fab-wa svg { width: 28px; height: 28px; }
            
            .btn-cta-domain { width: 100%; }
        }
    </style>
</head>
<body>

